# dokoro environment configuration
# Copy to .env.local and adjust. All values are optional unless noted —
# the server runs with sensible defaults and degrades gracefully.

# --- Workspace ---
# Path to the dokoro workspace/database root (defaults to the project's .dokoro).
DOKORO_PATH=

# --- AI / extraction (optional) ---
# Gemini API key — enables Gemini-backed features when set.
GEMINI_API_KEY=
# Qwen API key — optional alternate provider.
QWEN_API_KEY=
# Default AI model for planning/analysis features.
DOKORO_AI_MODEL=gpt-4.1-mini

# --- Ollama (optional, for embeddings + deep entity extraction) ---
# If unset, the server falls back to regex-based extraction and skips vector indexing.
OLLAMA_URL=http://localhost:11434
OLLAMA_INFERENCE_MODEL=llama3.2

# --- Feature flags (set to "true" to enable) ---
DOKORO_ENABLE_AI_PLANNING=false
DOKORO_ENABLE_AI_ANALYSIS=false
DOKORO_ENABLE_SEMANTIC_SEARCH=false
DOKORO_ENABLE_TACHIBOT_BRIDGE=false
# Set to "true" to disable automatic session capture.
DISABLE_AUTO_CAPTURE=false

# --- HTTP server (only for the HTTP transport) ---
MCP_PORT=3100
MCP_AUTH_PORT=3001
MCP_SERVER_URL=

# --- Tool configuration (optional) ---
# Inline JSON or a path to a tool-config file to enable/disable specific tools.
DOKORO_TOOL_CONFIG=
DOKORO_TOOL_CONFIG_PATH=

# --- Presentation (optional) ---
# Theme for rendered output (default: nebula). Icon mode: auto-detected from terminal.
DOKORO_THEME=nebula
DOKORO_ICON_MODE=
